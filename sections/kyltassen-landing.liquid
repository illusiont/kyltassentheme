<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@600;700;900&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">

{%- liquid
  assign product = section.settings.product
  assign price_label = '349 kr'
  if product
    assign price_label = product.price | money
  endif
-%}

<div class="kt-{{ section.id }}">
<style>
.kt-{{ section.id }} {
  --kt-primary: #2F6E73;
  --kt-primary-dark: #234F53;
  --kt-primary-fg: #FDFBF7;
  --kt-sand: #E8D9C0;
  --kt-sand-fg: #3B3226;
  --kt-cream: #FBF3E7;
  --kt-bg: #FDFAF4;
  --kt-fg: #262B33;
  --kt-muted: #6B7280;
  --kt-accent: #A9D6DA;
  --kt-border: #E7DFD1;
  --kt-radius: 1.5rem;
  font-family: 'Nunito', ui-sans-serif, system-ui, sans-serif;
  color: var(--kt-fg);
  background: var(--kt-bg);
  overflow-x: hidden;
}
.kt-{{ section.id }} * { box-sizing: border-box; }
.kt-{{ section.id }} h1, .kt-{{ section.id }} h2, .kt-{{ section.id }} h3 {
  font-family: 'Fraunces', ui-serif, Georgia, serif;
  font-weight: 900;
  letter-spacing: -0.02em;
  line-height: 1.08;
  margin: 0;
}
.kt-{{ section.id }} p { margin: 0; line-height: 1.6; }
.kt-{{ section.id }} .kt-wrap { max-width: 1160px; margin: 0 auto; padding: 0 20px; }
.kt-{{ section.id }} .kt-btn {
  display: inline-flex; align-items: center; justify-content: center;
  height: 56px; padding: 0 32px; border-radius: 999px;
  background: var(--kt-primary); color: var(--kt-primary-fg);
  font-weight: 700; font-size: 16px; text-decoration: none; border: none;
  cursor: pointer; box-shadow: 0 12px 24px -8px rgba(47,110,115,.35);
  transition: transform .15s ease, box-shadow .15s ease;
}
.kt-{{ section.id }} .kt-btn:hover { transform: translateY(-1px); box-shadow: 0 16px 28px -8px rgba(47,110,115,.45); }
.kt-{{ section.id }} .kt-btn svg { margin-left: 8px; }

/* HERO */
.kt-{{ section.id }} .kt-hero {
  position: relative;
  padding: 56px 0 72px;
  background: linear-gradient(to bottom, var(--kt-cream), var(--kt-bg));
}
.kt-{{ section.id }} .kt-hero-grid {
  display: grid; gap: 48px; align-items: center;
  grid-template-columns: 1fr;
}
@media (min-width: 860px) { .kt-{{ section.id }} .kt-hero-grid { grid-template-columns: 1fr 1fr; gap: 56px; } }
.kt-{{ section.id }} .kt-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--kt-sand); color: var(--kt-sand-fg);
  font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: .08em;
  padding: 6px 14px; border-radius: 999px;
}
.kt-{{ section.id }} .kt-h1 { font-size: clamp(2.1rem, 4.4vw, 3.6rem); margin-top: 20px; }
.kt-{{ section.id }} .kt-hero-copy { margin-top: 20px; font-size: 18px; color: var(--kt-fg); max-width: 34rem; opacity: .85; }
.kt-{{ section.id }} .kt-stars { display: flex; gap: 2px; }
.kt-{{ section.id }} .kt-rating { margin-top: 24px; display: flex; align-items: center; gap: 12px; font-size: 14px; }
.kt-{{ section.id }} .kt-rating b { font-weight: 800; }
.kt-{{ section.id }} .kt-rating span.muted { color: var(--kt-muted); }
.kt-{{ section.id }} .kt-cta-row { margin-top: 28px; display: flex; flex-wrap: wrap; align-items: center; gap: 18px; }
.kt-{{ section.id }} .kt-guarantee-line { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--kt-muted); }
.kt-{{ section.id }} .kt-hero-img-wrap { position: relative; }
.kt-{{ section.id }} .kt-hero-img-wrap img {
  width: 100%; height: auto; display: block; border-radius: 2rem;
  box-shadow: 0 30px 60px -20px rgba(47,110,115,.25); border: 1px solid var(--kt-border);
}

/* PAIN / DREAM */
.kt-{{ section.id }} .kt-pd { padding: 64px 0; }
.kt-{{ section.id }} .kt-pd-grid { display: grid; gap: 24px; grid-template-columns: 1fr; }
@media (min-width: 860px) { .kt-{{ section.id }} .kt-pd-grid { grid-template-columns: 1fr 1fr; gap: 32px; } }
.kt-{{ section.id }} .kt-pd-card { border-radius: 1.75rem; padding: 36px; }
.kt-{{ section.id }} .kt-pd-card.problem { background: rgba(232,217,192,.5); }
.kt-{{ section.id }} .kt-pd-card.solution {
  background: linear-gradient(135deg, var(--kt-primary), var(--kt-primary-dark));
  color: var(--kt-primary-fg); box-shadow: 0 20px 40px -14px rgba(47,110,115,.35);
}
.kt-{{ section.id }} .kt-eyebrow { font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: .08em; opacity: .75; }
.kt-{{ section.id }} .kt-pd-card h2 { font-size: clamp(1.5rem, 2.6vw, 2rem); margin-top: 10px; }
.kt-{{ section.id }} .kt-pd-card p { margin-top: 18px; opacity: .9; }
.kt-{{ section.id }} .kt-pd-card p.bold { font-weight: 700; opacity: 1; margin-top: 14px; }

/* BENEFITS */
.kt-{{ section.id }} .kt-benefits { background: var(--kt-cream); border-top: 1px solid var(--kt-border); border-bottom: 1px solid var(--kt-border); padding: 64px 0; }
.kt-{{ section.id }} .kt-section-head { text-align: center; max-width: 640px; margin: 0 auto; }
.kt-{{ section.id }} .kt-section-head h2 { font-size: clamp(1.8rem, 3.6vw, 2.6rem); }
.kt-{{ section.id }} .kt-section-head p { margin-top: 12px; color: var(--kt-muted); font-size: 17px; }
.kt-{{ section.id }} .kt-benefit-grid { margin-top: 44px; display: grid; gap: 18px; grid-template-columns: 1fr; }
@media (min-width: 620px) { .kt-{{ section.id }} .kt-benefit-grid { grid-template-columns: 1fr 1fr; } }
@media (min-width: 1000px) { .kt-{{ section.id }} .kt-benefit-grid { grid-template-columns: repeat(5, 1fr); } }
.kt-{{ section.id }} .kt-benefit-card {
  background: var(--kt-bg); border: 1px solid var(--kt-border); border-radius: 1.5rem; padding: 22px;
  transition: transform .15s ease, box-shadow .15s ease;
}
.kt-{{ section.id }} .kt-benefit-card:hover { transform: translateY(-3px); box-shadow: 0 14px 28px -14px rgba(0,0,0,.15); }
.kt-{{ section.id }} .kt-benefit-icon {
  height: 48px; width: 48px; border-radius: 1rem; background: rgba(47,110,115,.1);
  color: var(--kt-primary); display: grid; place-items: center; font-size: 22px;
}
.kt-{{ section.id }} .kt-benefit-card h3 { font-size: 18px; margin-top: 14px; }
.kt-{{ section.id }} .kt-benefit-card p { margin-top: 6px; font-size: 14px; color: var(--kt-muted); }

/* HOW IT WORKS */
.kt-{{ section.id }} .kt-how { padding: 64px 0; }
.kt-{{ section.id }} .kt-how-grid { display: grid; gap: 40px; grid-template-columns: 1fr; align-items: center; }
@media (min-width: 860px) { .kt-{{ section.id }} .kt-how-grid { grid-template-columns: 1fr 1fr; gap: 64px; } }
.kt-{{ section.id }} .kt-how-img img { width: 100%; border-radius: 2rem; box-shadow: 0 20px 40px -14px rgba(0,0,0,.15); }
.kt-{{ section.id }} .kt-how h2 { font-size: clamp(1.8rem, 3.6vw, 2.6rem); margin-top: 10px; }
.kt-{{ section.id }} .kt-steps { margin-top: 30px; display: flex; flex-direction: column; gap: 20px; }
.kt-{{ section.id }} .kt-step { display: flex; gap: 16px; }
.kt-{{ section.id }} .kt-step-num {
  flex: none; height: 36px; width: 36px; border-radius: 999px; background: var(--kt-primary); color: var(--kt-primary-fg);
  display: grid; place-items: center; font-weight: 800;
}
.kt-{{ section.id }} .kt-step h3 { font-size: 19px; }
.kt-{{ section.id }} .kt-step p { color: var(--kt-muted); margin-top: 2px; }
.kt-{{ section.id }} .kt-spec-box {
  margin-top: 30px; border: 2px dashed rgba(47,110,115,.35); background: rgba(47,110,115,.05);
  border-radius: 1.25rem; padding: 18px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; font-size: 14px;
}
.kt-{{ section.id }} .kt-spec-box .lab { font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: var(--kt-muted); }
.kt-{{ section.id }} .kt-spec-box .val { font-weight: 800; margin-top: 2px; }

/* REVIEWS */
.kt-{{ section.id }} .kt-reviews { background: var(--kt-cream); border-top: 1px solid var(--kt-border); border-bottom: 1px solid var(--kt-border); padding: 64px 0; }
.kt-{{ section.id }} .kt-rating-pill {
  display: inline-flex; align-items: center; gap: 10px; background: var(--kt-bg); border: 1px solid var(--kt-border);
  padding: 10px 18px; border-radius: 999px; box-shadow: 0 2px 8px rgba(0,0,0,.04);
}
.kt-{{ section.id }} .kt-review-grid { margin-top: 44px; display: grid; gap: 18px; grid-template-columns: 1fr; }
@media (min-width: 860px) { .kt-{{ section.id }} .kt-review-grid { grid-template-columns: repeat(3, 1fr); } }
.kt-{{ section.id }} .kt-review-card { background: var(--kt-bg); border: 1px solid var(--kt-border); border-radius: 1.5rem; padding: 24px; display: flex; flex-direction: column; }
.kt-{{ section.id }} .kt-review-card p.text { margin-top: 14px; flex: 1; }
.kt-{{ section.id }} .kt-review-foot { margin-top: 18px; padding-top: 14px; border-top: 1px solid var(--kt-border); }
.kt-{{ section.id }} .kt-review-foot .name { font-weight: 800; }
.kt-{{ section.id }} .kt-review-foot .dog { font-size: 12px; color: var(--kt-muted); }

/* GUARANTEE */
.kt-{{ section.id }} .kt-guarantee { padding: 64px 0; }
.kt-{{ section.id }} .kt-guarantee-box {
  max-width: 760px; margin: 0 auto; border-radius: 2rem; text-align: center; padding: 48px 32px;
  background: linear-gradient(135deg, var(--kt-primary), var(--kt-primary-dark)); color: var(--kt-primary-fg);
  box-shadow: 0 26px 50px -18px rgba(47,110,115,.4);
}
.kt-{{ section.id }} .kt-guarantee-box h2 { font-size: clamp(1.8rem, 3.4vw, 2.4rem); margin-top: 14px; }
.kt-{{ section.id }} .kt-guarantee-box p { margin-top: 14px; opacity: .92; max-width: 34rem; margin-left: auto; margin-right: auto; }
.kt-{{ section.id }} .kt-guarantee-list { margin-top: 24px; display: flex; flex-wrap: wrap; justify-content: center; gap: 8px 24px; font-size: 14px; list-style: none; padding: 0; }
.kt-{{ section.id }} .kt-guarantee-list li { display: flex; align-items: center; gap: 6px; }

/* FAQ */
.kt-{{ section.id }} .kt-faq { max-width: 760px; margin: 0 auto; padding: 64px 20px; }
.kt-{{ section.id }} .kt-faq h2 { text-align: center; font-size: clamp(1.8rem, 3.6vw, 2.6rem); }
.kt-{{ section.id }} .kt-faq-list { margin-top: 30px; }
.kt-{{ section.id }} details.kt-faq-item { border-bottom: 1px solid var(--kt-border); padding: 18px 0; }
.kt-{{ section.id }} details.kt-faq-item summary {
  cursor: pointer; list-style: none; font-family: 'Fraunces', serif; font-weight: 700; font-size: 18px;
  display: flex; justify-content: space-between; align-items: center; gap: 12px;
}
.kt-{{ section.id }} details.kt-faq-item summary::-webkit-details-marker { display: none; }
.kt-{{ section.id }} details.kt-faq-item summary .kt-plus { font-size: 22px; font-weight: 400; transition: transform .2s ease; color: var(--kt-primary); }
.kt-{{ section.id }} details.kt-faq-item[open] summary .kt-plus { transform: rotate(45deg); }
.kt-{{ section.id }} details.kt-faq-item .kt-faq-a { margin-top: 10px; color: var(--kt-muted); line-height: 1.6; }
.kt-{{ section.id }} .kt-faq-cta { margin-top: 40px; text-align: center; }

/* STICKY MOBILE CTA */
.kt-{{ section.id }} .kt-sticky {
  display: none; position: fixed; left: 0; right: 0; bottom: 0; z-index: 999;
  background: rgba(253,250,244,.97); backdrop-filter: blur(6px);
  border-top: 1px solid var(--kt-border); padding: 12px 16px;
  align-items: center; justify-content: space-between; gap: 12px;
  box-shadow: 0 -8px 24px -8px rgba(0,0,0,.1);
}
.kt-{{ section.id }} .kt-sticky .kt-sticky-price { font-family: 'Fraunces', serif; font-weight: 900; font-size: 22px; }
.kt-{{ section.id }} .kt-sticky .kt-sticky-sub { font-size: 12px; color: var(--kt-muted); }
.kt-{{ section.id }} .kt-sticky .kt-btn { flex: 1; max-width: 62%; height: 48px; padding: 0; }
@media (max-width: 767px) {
  .kt-{{ section.id }} .kt-sticky { display: flex; }
  .kt-{{ section.id }} .kt-sticky-spacer { display: block; height: 84px; }
}
</style>

  {%- comment -%} HERO {%- endcomment -%}
  <section class="kt-hero">
    <div class="kt-wrap kt-hero-grid">
      <div>
        <span class="kt-badge">❄ {{ section.settings.badge_text | default: 'Svalka utan el' }}</span>
        <h1 class="kt-h1">{{ section.settings.hero_heading | default: 'Din hund lider tyst i värmen — och du märker det knappt.' }}</h1>
        <p class="kt-hero-copy">{{ section.settings.hero_text | default: 'Föreställ dig istället en lugn, sval hund som andas normalt och sover djupt — även när termometern visar 28 grader. Kyltassen ger omedelbar svalka. Ingen el. Ingen frys.' }}</p>

        <div class="kt-rating">
          <span class="kt-stars"><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg></span>
          <b>{{ section.settings.rating | default: '4.8/5' }}</b>
          <span class="muted">· {{ section.settings.review_count | default: '800+ nöjda hundägare' }}</span>
        </div>

        <div class="kt-cta-row">
          {%- if product -%}
          <a href="{{ product.url }}" class="kt-btn">
            Köp nu — {{ price_label }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          {%- else -%}
          <a href="#{{ section.id }}-buy" class="kt-btn">
            Köp nu — {{ price_label }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          {%- endif -%}
          <div class="kt-guarantee-line">🛡 {{ section.settings.guarantee_line | default: '30 dagars öppet köp · Fri frakt' }}</div>
        </div>
      </div>

      <div class="kt-hero-img-wrap">
        {%- if section.settings.hero_image -%}
          {{ section.settings.hero_image | image_url: width: 1600 | image_tag: loading: 'eager', alt: section.settings.hero_heading }}
        {%- else -%}
          <div style="aspect-ratio:4/3;border-radius:2rem;background:var(--kt-sand);display:grid;place-items:center;color:var(--kt-sand-fg);font-weight:700;">
            Ladda upp en hero-bild i sektionsinställningarna
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} PAIN / DREAM {%- endcomment -%}
  <section class="kt-pd">
    <div class="kt-wrap kt-pd-grid">
      <div class="kt-pd-card problem">
        <span class="kt-eyebrow">Verkligheten</span>
        <h2>Din hund kan inte säga det till dig. Men hen försöker.</h2>
        <p>Flämtande andning. Trycker magen mot det svala golvet. Ligger stilla i skuggan istället för att leka. Många hundar går runt överhettade i veckor utan att vi märker det.</p>
        <p class="bold">Det är inte ditt fel att du inte sett tecknen. Men nu vet du.</p>
      </div>
      <div class="kt-pd-card solution">
        <span class="kt-eyebrow">Med {{ shop.name }}</span>
        <h2>En trygg, sval plats — alltid där hunden behöver den.</h2>
        <p>Föreställ dig: din hund sträcker ut sig avslappnad på en sval yta, andas lugnt, sover djupt mitt på dagen — även när termometern visar 28 grader.</p>
      </div>
    </div>
  </section>

  {%- comment -%} BENEFITS {%- endcomment -%}
  <section class="kt-benefits">
    <div class="kt-wrap">
      <div class="kt-section-head">
        <h2>Skillnad från första dagen</h2>
        <p>Fem konkreta saker som förändras när {{ shop.name }} kommer in i hemmet.</p>
      </div>
      <div class="kt-benefit-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'benefit' -%}
          <div class="kt-benefit-card" {{ block.shopify_attributes }}>
            <div class="kt-benefit-icon">{{ block.settings.icon | default: '❄' }}</div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment -%} HOW IT WORKS {%- endcomment -%}
  <section class="kt-how">
    <div class="kt-wrap kt-how-grid">
      <div class="kt-how-img">
        {%- if section.settings.detail_image -%}
          {{ section.settings.detail_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: 'Produktdetalj' }}
        {%- else -%}
          <div style="aspect-ratio:1/1;border-radius:2rem;background:var(--kt-accent);"></div>
        {%- endif -%}
      </div>
      <div>
        <span class="kt-eyebrow" style="color:var(--kt-primary);">Så här fungerar det</span>
        <h2>{{ section.settings.how_heading | default: '4 lager. 0 el. All svalka.' }}</h2>
        <div class="kt-steps">
          {%- for block in section.blocks -%}
            {%- if block.type == 'step' -%}
            <div class="kt-step" {{ block.shopify_attributes }}>
              <div class="kt-step-num">{{ forloop.index }}</div>
              <div>
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.text }}</p>
              </div>
            </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <div class="kt-spec-box">
          <div><div class="lab">Storlek</div><div class="val">{{ section.settings.spec_size | default: '70 × 55 cm' }}</div></div>
          <div><div class="lab">Aktivering</div><div class="val">{{ section.settings.spec_activation | default: 'Tryck — ingen el' }}</div></div>
          <div><div class="lab">Rengöring</div><div class="val">{{ section.settings.spec_cleaning | default: 'Fuktig trasa' }}</div></div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} REVIEWS {%- endcomment -%}
  <section class="kt-reviews">
    <div class="kt-wrap">
      <div style="text-align:center;">
        <div class="kt-rating-pill">
          <span class="kt-stars"><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg></span>
          <b>{{ section.settings.rating | default: '4.8/5' }}</b>
          <span class="muted">· {{ section.settings.review_count | default: '800+ nöjda hundägare' }}</span>
        </div>
        <h2 style="margin-top:24px;font-size:clamp(1.8rem,3.6vw,2.6rem);">Vad hundägare säger</h2>
        <p style="margin-top:12px;color:var(--kt-muted);max-width:34rem;margin-left:auto;margin-right:auto;">Från golden retrievers till border collies — hundar över hela Sverige njuter av svalare dagar.</p>
      </div>
      <div class="kt-review-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
          <div class="kt-review-card" {{ block.shopify_attributes }}>
            <span class="kt-stars"><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg><svg width="16" height="16" viewBox="0 0 24 24" fill="#2F6E73" stroke="#2F6E73"><path d="M12 2l2.9 6.6L22 9.3l-5 4.8L18.2 21 12 17.3 5.8 21 7 14.1l-5-4.8 7.1-.7z"/></svg></span>
            <p class="text">"{{ block.settings.text }}"</p>
            <div class="kt-review-foot">
              <div class="name">{{ block.settings.name }}</div>
              <div class="dog">{{ block.settings.dog }}</div>
            </div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment -%} GUARANTEE {%- endcomment -%}
  <section class="kt-guarantee">
    <div class="kt-wrap">
      <div class="kt-guarantee-box">
        <div style="font-size:40px;">🛡</div>
        <h2>{{ section.settings.guarantee_heading | default: '30 dagars öppet köp' }}</h2>
        <p>{{ section.settings.guarantee_text | default: 'Älskar inte din hund sin nya svala plats? Skicka tillbaka mattan inom 30 dagar och få pengarna tillbaka. Ingen risk, inga frågor.' }}</p>
        <ul class="kt-guarantee-list">
          <li>✓ Fri frakt</li>
          <li>✓ Snabb leverans i Sverige</li>
          <li>✓ Svensk kundtjänst</li>
        </ul>
      </div>
    </div>
  </section>

  {%- comment -%} FAQ {%- endcomment -%}
  <section class="kt-faq">
    <h2>Vanliga frågor</h2>
    <div class="kt-faq-list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}
        <details class="kt-faq-item" {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}<span class="kt-plus">+</span></summary>
          <div class="kt-faq-a">{{ block.settings.answer }}</div>
        </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="kt-faq-cta">
      {%- if product -%}
      <a href="{{ product.url }}" class="kt-btn">Till produktsidan
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      {%- endif -%}
    </div>
  </section>

  {%- comment -%} BUY BOX / ADD TO CART {%- endcomment -%}
  {%- if product -%}
  <section id="{{ section.id }}-buy" class="kt-guarantee" style="padding-top:0;">
    <div class="kt-wrap" style="max-width:520px;">
      <form method="post" action="{{ routes.cart_add_url }}" id="{{ section.id }}-form" style="text-align:center;border:1px solid var(--kt-border);border-radius:1.5rem;padding:32px;background:var(--kt-cream);">
        <h3 style="font-family:'Fraunces',serif;font-size:22px;">{{ product.title }}</h3>
        <p style="margin-top:8px;font-family:'Fraunces',serif;font-weight:900;font-size:28px;">{{ price_label }}</p>
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <label style="display:block;margin-top:16px;font-size:13px;font-weight:700;">Antal
          <select name="quantity" style="display:block;width:100%;margin-top:6px;height:44px;border-radius:.75rem;border:1px solid var(--kt-border);text-align:center;">
            <option value="1">1 st</option>
            <option value="2">2 st</option>
            <option value="3">3 st</option>
          </select>
        </label>
        <button type="submit" class="kt-btn" style="margin-top:20px;width:100%;">Lägg i kundvagn</button>
      </form>
    </div>
  </section>
  {%- endif -%}

  {%- comment -%} STICKY MOBILE CTA {%- endcomment -%}
  <div class="kt-sticky">
    <div>
      <div class="kt-sticky-sub">{{ section.settings.sticky_label | default: 'Kyltassen 70×55' }}</div>
      <div class="kt-sticky-price">{{ price_label }}</div>
    </div>
    {%- if product -%}
    <a href="#{{ section.id }}-buy" class="kt-btn">Köp nu</a>
    {%- else -%}
    <a href="#" class="kt-btn">Köp nu</a>
    {%- endif -%}
  </div>
  <div class="kt-sticky-spacer"></div>
</div>

